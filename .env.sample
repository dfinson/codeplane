# Tunnel authentication password (used by `cpl up --remote`)
CPL_TUNNEL_PASSWORD=

# Cloudflare Tunnel credentials (used by `cpl up --remote --provider cloudflare`)
# Create a named tunnel at https://one.dash.cloudflare.com/ and route a public
# hostname to localhost, then paste the tunnel token and public hostname below.
CPL_CLOUDFLARE_TUNNEL_TOKEN=
CPL_CLOUDFLARE_HOSTNAME=
